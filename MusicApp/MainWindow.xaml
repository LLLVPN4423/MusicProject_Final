<Window x:Class="MusicApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Music Player"
        Height="800"
        Width="1400"
        MinHeight="640"
        MinWidth="1200"
        FontFamily="Bahnschrift"
        Background="#6F6B69"
        WindowStartupLocation="CenterScreen"
        >
    <Window.Resources>
        <SolidColorBrush x:Key="BaseBgBrush" Color="#6F6B69"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#5B5755"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#807B79"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#C07CC7"/>
        <SolidColorBrush x:Key="SoftWhiteBrush" Color="#F4F0EC"/>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderThickness="0">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                          To="#C07CC7" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX"
                                                           To="1.05" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY"
                                                           To="1.05" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                          To="#8D8886" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX"
                                                           To="1.0" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY"
                                                           To="1.0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#A08D9C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Transport Button Style -->
        <Style x:Key="TransportButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F6F5F2"/>
            <Setter Property="Foreground" Value="#5C5957"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="25"
                                BorderThickness="0">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.2"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                          To="#E8E6E1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX"
                                                           To="1.1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY"
                                                           To="1.1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                          To="#F6F5F2" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX"
                                                           To="1.0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY"
                                                           To="1.0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D8D4D2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab Button Style -->
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#8D8886"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8,8,0,0"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                          To="#A08D9C" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                          To="#8D8886" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#F6F5F2"/>
            <Setter Property="Foreground" Value="#5C5957"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D8D4D2"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontFamily" Value="Bahnschrift"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                        Margin="{TemplateBinding Padding}"
                                        VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#C07CC7"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#C07CC7"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Simple Slider Style -->
        <Style x:Key="ModernSliderStyle" TargetType="Slider">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C07CC7"/>
        </Style>

        <!-- Modern ListViewItem Style -->
        <Style x:Key="ModernListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Foreground" Value="#5C5957"/>
            <Setter Property="FontFamily" Value="Bahnschrift"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="itemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#E8E6E1"/>
                                <Setter Property="Foreground" Value="#2F2D2C"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#C07CC7"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Foreground" Value="#2F2D2C"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="itemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter Margin="4"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#EDEAE8"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#C07CC7"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BaseBgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border x:Name="sidebarBorder" Grid.Column="0" Background="#5C5856">
            <StackPanel Margin="26,32">
                <TextBlock x:Name="logoText" Text="🎵 Music Player"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#F1EFEB"
                           Margin="0,0,0,20"/>

                <Button x:Name="btnMenu"
                        AutomationProperties.AutomationId="btnMenu"
                        Content="📋 Menu"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="MenuButton_Click"
                        Margin="0,14,0,0"/>

                <StackPanel x:Name="menuItemsPanel"
                            Visibility="Collapsed"
                            Margin="0,10,0,0">
                    <Button x:Name="btnOpenFolder"
                            AutomationProperties.AutomationId="btnOpenFolder"
                            Content="📁 Mở Thư mục"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnOpenFolder_Click"
                            Margin="0,0,0,10"/>
                    <Button x:Name="btnOpenFile"
                            AutomationProperties.AutomationId="btnOpenFile"
                            Content="🎶 Mở tệp"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnOpenFile_Click"
                            Margin="0,0,0,10"/>
                    <Button x:Name="btnPlaylist"
                            AutomationProperties.AutomationId="btnPlaylist"
                            Content="🎵 Danh sách phát"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnPlaylist_Click"
                            Margin="0,0,0,10"/>
                    <Button x:Name="btnFavorites"
                            AutomationProperties.AutomationId="btnFavorites"
                            Content="❤️ Yêu thích"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnFavorites_Click"
                            Margin="0,0,0,10"/>
                    <Button x:Name="btnHistory"
                            AutomationProperties.AutomationId="btnHistory"
                            Content="📚 Lịch sử nghe"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnHistory_Click"
                            Margin="0,0,0,10"/>
                    <Button x:Name="btnTheme"
                            AutomationProperties.AutomationId="btnTheme"
                            Content="🎨 Giao diện"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnTheme_Click"
                            Margin="0,0,0,10"/>
                    <Button x:Name="btnSettings"
                            AutomationProperties.AutomationId="btnSettings"
                            Content="⚙️ Cài đặt"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnSettings_Click"
                            Margin="0,0,0,10"/>
                    <Button x:Name="btnAbout"
                            AutomationProperties.AutomationId="btnAbout"
                            Content="ℹ️ Thông tin"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnAbout_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Surface -->
        <Grid x:Name="mainSurface" Grid.Column="1" Background="#7C7876">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Main Player Screen"
                       FontSize="20"
                       Foreground="#EDE9E6"
                       HorizontalAlignment="Center"
                       Margin="0,24,0,24"/>

            <Grid Grid.Row="1" Margin="60,0,60,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,30,0">
                    <Border Background="#FDFBFA"
                            CornerRadius="22"
                            Height="320"
                            Padding="30">
                        <Border Background="#FFFFFF"
                                CornerRadius="18"
                                BorderBrush="#D8D4D2"
                                BorderThickness="1">
                            <Grid>
                                <MediaElement x:Name="videoPreview"
                                              LoadedBehavior="Manual"
                                              UnloadedBehavior="Manual"
                                              Stretch="Uniform"
                                              Visibility="Collapsed"
                                              IsMuted="True"/>
                                <Image x:Name="imgPreview"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                                <TextBlock x:Name="lblImagePlaceholder"
                                           Text="Image"
                                           FontSize="48"
                                           Foreground="#C3BEBB"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Border>

                    <StackPanel Margin="0,26,0,0">
                        <TextBlock x:Name="lblTrackTitleLabel" Text="Tên bài hát"
                                   Foreground="#D6D1CF"
                                   FontSize="11"
                                   FontWeight="Medium"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="lblTrackTitle"
                                   Text="Chưa có bài hát"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Margin="0,0,0,14"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"/>

                        <TextBlock x:Name="lblArtistLabel" Text="Ca sĩ"
                                   Foreground="#D6D1CF"
                                   FontSize="11"
                                   FontWeight="Medium"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="lblArtist"
                                   Text="Thêm bài hát để bắt đầu"
                                   Foreground="#F7F3F0"
                                   FontSize="15"
                                   FontWeight="Light"
                                   Margin="0,0,0,18"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"/>

                        <TextBlock x:Name="lblStatusLabel" Text="Trạng thái"
                                   Foreground="#D6D1CF"
                                   FontSize="11"
                                   FontWeight="Medium"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="lblStatus"
                                   Text="Idle"
                                   Foreground="#F7F3F0"
                                   FontSize="14"
                                   FontWeight="Light"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"/>
                    </StackPanel>
                </StackPanel>

                <Border x:Name="playlistPanel" Grid.Column="1"
                        Background="#A29D9A"
                        CornerRadius="18"
                        Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Tab Headers with Modern Icons -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Search Bar -->
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBox x:Name="txtSearch"
                                         Grid.Column="0"
                                         Text=""
                                         TextChanged="TxtSearch_TextChanged"
                                         Style="{StaticResource ModernTextBoxStyle}"
                                         Margin="0,0,10,0"/>
                                
                                <Button x:Name="btnClearSearch"
                                        Grid.Column="1"
                                        Content="🗑️"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Width="40"
                                        Height="40"
                                        Click="BtnClearSearch_Click"
                                        ToolTip="Xóa tìm kiếm"/>
                            </Grid>
                            
                            <!-- Tab Buttons -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Button x:Name="btnPlaylistTab"
                                        Grid.Column="0"
                                        Content="🎵 Playlist"
                                        Style="{StaticResource TabButtonStyle}"
                                        Click="BtnPlaylistTab_Click"/>
                                
                                <Button x:Name="btnFavoritesTab"
                                        Grid.Column="1"
                                        Content="❤️ Yêu thích"
                                        Style="{StaticResource TabButtonStyle}"
                                        Click="BtnFavoritesTab_Click"/>
                                
                                <Button x:Name="btnHistoryTab"
                                        Grid.Column="2"
                                        Content="📚 Lịch sử"
                                        Style="{StaticResource TabButtonStyle}"
                                        Click="BtnHistoryTab_Click"/>
                            </Grid>
                        </Grid>

                        <!-- Content Grid -->
                        <Grid Grid.Row="1">
                            <!-- Playlist View with Modern Design -->
                            <Grid x:Name="playlistView">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Modern Header -->
                                <Border Grid.Row="0" 
                                       Background="#9A9592"
                                       CornerRadius="12,12,0,0"
                                       Padding="20,15"
                                       Margin="0,0,0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Text="#" 
                                                   Grid.Column="0"
                                                   Foreground="#F2EFEA"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Tên bài hát" 
                                                   Grid.Column="1"
                                                   Foreground="#F2EFEA"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Ca sĩ" 
                                                   Grid.Column="2"
                                                   Foreground="#F2EFEA"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Thời gian" 
                                                   Grid.Column="3"
                                                   Foreground="#F2EFEA"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Modern ListView -->
                                <Border Grid.Row="1" 
                                       Background="#F6F5F2"
                                       CornerRadius="0,0,12,12"
                                       Padding="10">
                                    <ListView x:Name="lvPlaylist"
                                              ItemsSource="{Binding SearchResults}"
                                              ItemContainerStyle="{StaticResource ModernListViewItemStyle}"
                                              BorderThickness="0"
                                              Background="Transparent"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              MouseDoubleClick="LvPlaylist_MouseDoubleClick">
                                        <ListView.View>
                                            <GridView AllowsColumnReorder="False">
                                                <GridViewColumn Header="" Width="50" DisplayMemberBinding="{Binding Sequence}"/>
                                                <GridViewColumn Header="" Width="280" DisplayMemberBinding="{Binding Title}"/>
                                                <GridViewColumn Header="" Width="120" DisplayMemberBinding="{Binding Artist}"/>
                                                <GridViewColumn Header="" Width="80" DisplayMemberBinding="{Binding DurationText}"/>
                                                <GridViewColumn Header="" Width="40"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </Border>
                            </Grid>

                            <!-- Favorites View -->
                            <Grid x:Name="favoritesView" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="STT"
                                               Foreground="#F2EFEA"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Title"
                                               Grid.Column="1"
                                               Foreground="#F2EFEA"
                                               FontWeight="Bold"/>
                                    <TextBlock Text="Singer"
                                               Grid.Column="2"
                                               Foreground="#F2EFEA"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Time"
                                               Grid.Column="3"
                                               Foreground="#F2EFEA"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                </Grid>

                                <ListView Grid.Row="1"
                                          x:Name="lvFavorites"
                                          ItemsSource="{Binding SearchResults}"
                                          BorderThickness="0"
                                          Background="#D8D4D2"
                                          ItemContainerStyle="{StaticResource ListViewItemStyle}"
                                          SelectionMode="Single"
                                          MouseDoubleClick="LvFavorites_MouseDoubleClick">
                                    <ListView.View>
                                        <GridView AllowsColumnReorder="False">
                                            <GridViewColumn Header="STT" Width="60" DisplayMemberBinding="{Binding Sequence}"/>
                                            <GridViewColumn Header="Title" Width="140" DisplayMemberBinding="{Binding Title}"/>
                                            <GridViewColumn Header="Singer" Width="100" DisplayMemberBinding="{Binding Artist}"/>
                                            <GridViewColumn Header="Time" Width="70" DisplayMemberBinding="{Binding DurationText}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Grid>

                            <!-- History View -->
                            <Grid x:Name="historyView" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="STT"
                                               Foreground="#F2EFEA"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Title"
                                               Grid.Column="1"
                                               Foreground="#F2EFEA"
                                               FontWeight="Bold"/>
                                    <TextBlock Text="Singer"
                                               Grid.Column="2"
                                               Foreground="#F2EFEA"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Time"
                                               Grid.Column="3"
                                               Foreground="#F2EFEA"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Ngày phát"
                                               Grid.Column="4"
                                               Foreground="#F2EFEA"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                </Grid>

                                <ListView Grid.Row="1"
                                          x:Name="lvHistory"
                                          ItemsSource="{Binding SearchResults}"
                                          BorderThickness="0"
                                          Background="#D8D4D2"
                                          ItemContainerStyle="{StaticResource ListViewItemStyle}"
                                          SelectionMode="Single"
                                          MouseDoubleClick="LvHistory_MouseDoubleClick">
                                    <ListView.View>
                                        <GridView AllowsColumnReorder="False">
                                            <GridViewColumn Header="STT" Width="60" DisplayMemberBinding="{Binding Sequence}"/>
                                            <GridViewColumn Header="Title" Width="140" DisplayMemberBinding="{Binding Title}"/>
                                            <GridViewColumn Header="Singer" Width="100" DisplayMemberBinding="{Binding Artist}"/>
                                            <GridViewColumn Header="Time" Width="70" DisplayMemberBinding="{Binding DurationText}"/>
                                            <GridViewColumn Header="Ngày phát" Width="120" DisplayMemberBinding="{Binding LastPlayed, StringFormat='{}{0:dd/MM HH:mm}'}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="80,20,80,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,20,0">
                    <Border Background="#BEB9B7"
                            Height="10"
                            VerticalAlignment="Center"
                            CornerRadius="5"/>
                    <Slider x:Name="sldProgress"
                            AutomationProperties.AutomationId="sldProgress"
                            Minimum="0"
                            Maximum="1"
                            Value="0"
                            Background="Transparent"
                            Height="14"
                            Foreground="#C07CC7"
                            Thumb.DragStarted="Progress_DragStarted"
                            Thumb.DragCompleted="Progress_DragCompleted"
                            PreviewMouseLeftButtonUp="Progress_MouseLeftButtonUp"/>
                </Grid>

                <TextBlock x:Name="lblTimeDisplay"
                           Grid.Column="1"
                           Text="00:00 / 00:00"
                           Foreground="#F4F0EC"
                           FontSize="14"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Compact Transport Controls -->
            <Border Grid.Row="3"
                    Margin="120,20"
                    Background="#8D8886"
                    CornerRadius="35"
                    Height="90">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left controls: Shuffle and Repeat -->
                    <StackPanel Orientation="Horizontal" 
                                VerticalAlignment="Center" 
                                Grid.Column="0"
                                HorizontalAlignment="Left"
                                Margin="30,0,0,0">
                        <Button x:Name="btnShuffle"
                                AutomationProperties.AutomationId="btnShuffle"
                                Content="🔀"
                                Style="{StaticResource TransportButtonStyle}"
                                Width="45"
                                Height="45"
                                FontSize="18"
                                Click="BtnShuffle_Click"/>
                        <Button x:Name="btnRepeat"
                                AutomationProperties.AutomationId="btnRepeat"
                                Content="🔁"
                                Style="{StaticResource TransportButtonStyle}"
                                Width="45"
                                Height="45"
                                FontSize="18"
                                Margin="8,0,0,0"
                                Click="BtnRepeat_Click"/>
                    </StackPanel>
                    
                    <!-- Center controls: Prev, Play/Pause, Next -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Grid.Column="1">
                        <Button x:Name="btnPrev"
                                AutomationProperties.AutomationId="btnPrev"
                                Content="⏮"
                                Style="{StaticResource TransportButtonStyle}"
                                FontSize="18"
                                Margin="0,0,15,0"
                                Click="BtnPrev_Click"/>
                        <Button x:Name="btnPause"
                                AutomationProperties.AutomationId="btnPause"
                                Content="⏸"
                                Background="#F1B3B3"
                                Foreground="White"
                                Style="{StaticResource TransportButtonStyle}"
                                FontSize="18"
                                Width="55"
                                Height="55"
                                Margin="0,0,15,0"
                                Click="BtnPause_Click"/>
                        <Button x:Name="btnNext"
                                AutomationProperties.AutomationId="btnNext"
                                Content="⏭"
                                Style="{StaticResource TransportButtonStyle}"
                                FontSize="18"
                                Click="BtnNext_Click"/>
                    </StackPanel>
                    
                    <!-- Right controls: Volume -->
                    <StackPanel Orientation="Horizontal" 
                                VerticalAlignment="Center" 
                                Grid.Column="2"
                                HorizontalAlignment="Right"
                                Margin="0,0,30,0">
                        <Button x:Name="btnMute"
                                AutomationProperties.AutomationId="btnMute"
                                Content="🔊"
                                Style="{StaticResource TransportButtonStyle}"
                                Width="45"
                                Height="45"
                                FontSize="18"
                                Click="BtnMute_Click"/>
                        <Border Background="#F6F5F2"
                                CornerRadius="20"
                                Margin="8,0,0,0"
                                Width="120"
                                Height="45"
                                VerticalAlignment="Center">
                            <Slider x:Name="sldVolume"
                                    AutomationProperties.AutomationId="sldVolume"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="0.5"
                                    Background="Transparent"
                                    Margin="10,0"
                                    ValueChanged="SldVolume_ValueChanged"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
